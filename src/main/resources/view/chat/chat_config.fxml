<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="config" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ucsal.sergiolj.containers.chat.gui.controller.ConfigController">
    <GridPane hgap="10.0" vgap="10.0">
          <Label text="Server Name" />
        <TextField fx:id="txf_server_name" prefHeight="40.0" prefWidth="200.0" promptText="server name" GridPane.columnIndex="1" />
        <Label text="Internet Address IPv4" GridPane.rowIndex="1" />
        <TextField fx:id="txf_ip_address" prefHeight="40.0" prefWidth="200.0" promptText="IP Address" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label text="Server Port" GridPane.rowIndex="2" />
        <TextField fx:id="txf_server_port" prefHeight="40.0" prefWidth="200.0" promptText="Server port" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <padding>
          <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
    </GridPane>
    <HBox alignment="CENTER" spacing="20.0">
        <VBox.margin>
            <Insets bottom="20.0" />
        </VBox.margin>
        <Button contentDisplay="CENTER" mnemonicParsing="false" onAction="#closeWindow" prefWidth="100.0" text="Cancel" />
        <Button fx:id="btn_save" mnemonicParsing="false" onAction="#saveAndClose" prefWidth="100.0" text="Save" />
    </HBox>
</VBox>
